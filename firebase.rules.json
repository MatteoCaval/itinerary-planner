{
  "rules": {
    "users": {
      "$uid": {
        ".read": "auth !== null && auth.uid === $uid",
        ".write": "auth !== null && auth.uid === $uid"
      }
    },
    "itineraries": {
      ".read": true,
      ".write": true
    },
    "feedback": {
      ".read": false,
      "$id": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['text', 'timestamp'])",
        "text": {
          ".validate": "newData.isString() && newData.val().length > 0 && newData.val().length <= 2000"
        },
        "timestamp": {
          ".validate": "newData.val() == now"
        }
      }
    }
  }
}
